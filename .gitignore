node_modules/
dist/
build/
coverage/
.vite/
*.log

# Local reference implementations — not vendored
/references/

# Claude Code local state (worktrees, machine-local config — settings.json
# and skills/ are versioned; worktrees and other state are not)
.claude/*
!/.claude/settings.json
!/.claude/skills/

# OBJ provenance archive — source files for the test corpus; not imported by anything
test/corpus/OBJ format/

# Editor history (VS Code Local History extension)
.history/

# Brainstorm skill runtime state (HTML scratchpads, server PIDs)
.superpowers/

# Session 0030+ visual-gate captures (transient, regenerated per session)
docs/sessions/*/before.png
docs/sessions/*/after.png

# Throwaway probe scripts (per-session diagnostic tooling)
scripts/probe-*.ts

# Playwright artifacts
test-results/
playwright-report/
.playwright/

# macOS
.DS_Store
